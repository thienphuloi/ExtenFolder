      "run_at": "document_idle"
   } ],
   "description": "Tự động tải hóa đơn điện tử từ cổng thuế GDT. Xuất XML, Excel, HTML, PDF. Tiết kiệm hàng giờ. Hoàn toàn miễn phí.",
   "host_permissions": [ "https://hoadondientu.gdt.gov.vn/*" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Tải Hóa Đơn Điện Tử - Nguyễn Bá Lợi",
   "permissions": [ "scripting", "downloads", "storage", "unlimitedStorage", "offscreen", "activeTab" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.3.1",
   "web_accessible_resources": [ {
      "matches": [ "https://hoadondientu.gdt.gov.vn/*" ],
