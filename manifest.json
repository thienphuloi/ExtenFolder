         "16": "icons/icon16.png",
         "48": "icons/icon48.png"
      },
      "default_title": "Tải Hóa Đơn điện tử"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
